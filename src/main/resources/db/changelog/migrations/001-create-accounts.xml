<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <changeSet id="001-create-accounts" author="aiylbank">
        <createTable tableName="accounts">
            <column name="id" type="BIGSERIAL">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="account_number" type="VARCHAR(20)">
                <constraints unique="true" nullable="false"/>
            </column>
            <column name="owner_name" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
            <column name="balance" type="NUMERIC(19,2)" defaultValue="0.00">
                <constraints nullable="false"/>
            </column>
            <column name="status" type="VARCHAR(20)" defaultValue="ACTIVE">
                <constraints nullable="false"/>
            </column>
            <column name="created_at" type="TIMESTAMP" defaultValueComputed="NOW()">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <sql>
            ALTER TABLE accounts
            ADD CONSTRAINT chk_accounts_status
            CHECK (status IN ('ACTIVE','BLOCKED','CLOSED'));
        </sql>

        <rollback>
            <dropTable tableName="accounts"/>
        </rollback>
    </changeSet>

</databaseChangeLog>