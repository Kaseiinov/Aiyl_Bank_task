<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <changeSet id="003-create-indexes" author="aiylbank">

        <createIndex tableName="accounts" indexName="idx_accounts_account_number">
            <column name="account_number"/>
        </createIndex>

        <createIndex tableName="transactions" indexName="idx_transactions_created_at">
            <column name="created_at"/>
        </createIndex>

        <createIndex tableName="transactions" indexName="idx_transactions_source_account">
            <column name="source_account_id"/>
        </createIndex>

        <createIndex tableName="transactions" indexName="idx_transactions_target_account">
            <column name="target_account_id"/>
        </createIndex>

        <createIndex tableName="transactions" indexName="idx_transactions_source_created">
            <column name="source_account_id"/>
            <column name="created_at" descending="true"/>
        </createIndex>

        <createIndex tableName="transactions" indexName="idx_transactions_target_created">
            <column name="target_account_id"/>
            <column name="created_at" descending="true"/>
        </createIndex>

        <rollback>
            <dropIndex tableName="transactions" indexName="idx_transactions_target_created"/>
            <dropIndex tableName="transactions" indexName="idx_transactions_source_created"/>
            <dropIndex tableName="transactions" indexName="idx_transactions_target_account"/>
            <dropIndex tableName="transactions" indexName="idx_transactions_source_account"/>
            <dropIndex tableName="transactions" indexName="idx_transactions_created_at"/>
            <dropIndex tableName="accounts"     indexName="idx_accounts_account_number"/>
        </rollback>
    </changeSet>

</databaseChangeLog>